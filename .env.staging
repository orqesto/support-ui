# Staging Environment Variables
# Single-origin (mirrors prod app.odly.ai): the API is served same-origin under
# /api on the staging domain, proxied by nginx to the staging backend on :3003.
# NOTE: CI (deploy-production.yml) injects these at build time for the `staging`
# branch; this file is the source of truth for local `vite build --mode staging`.
VITE_API_URL=https://staging.app.odly.ai
VITE_WS_URL=wss://staging.app.odly.ai
VITE_APP_URL=https://staging.app.odly.ai
VITE_SENTRY_DSN=
VITE_ENABLE_DEBUG=true
VITE_LOG_LEVEL=debug
